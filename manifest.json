{
  "manifest_version": 3,
  "name": "Offline Prompt Tester",
  "version": "1.0.0",
  "description": "Test prompt perturbations offline with Jan.ai, Ollama, LM Studio & custom LLMs",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Offline Prompt Tester"
  },
  "background": {
    "service_worker": "background.ts"
  },
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["http://localhost/*", "https://api.gumroad.com/*"],
  "omnibox": { "keyword": "pt" }
}
